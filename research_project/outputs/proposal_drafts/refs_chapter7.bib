url = {https://doi.org/10.1145/3486626.3493429},
doi = {10.1145/3486626.3493429},
abstract = {Electric vehicles (EV) are an emerging mode of transportation, and big cities in the United States have witnessed an ever-growing demand for EV usage. The primary benefit of EVs is the high fuel efficiency by using only electricity, and hence lowers the dependency on fossil fuels and significantly reduces greenhouse gas emissions. Although the number of EVs has increased, the availability of EV charging stations for public use has been disproportionate to its demand. More recently, populations residing in the Southern California region have been faced with challenges such as range anxiety owing to the uneven spatial distribution of charging stations throughout the region. As the EV population continues to expand, identifying hotspots of EV charging and barriers to the equitable access of charging stations have gained much importance. Our study uses a geospatial data fusion approach with spatial statistics to combine EV charging station data, land use information, and American Community Survey (ACS) data at the census block group level in Orange County, California to discover optimal locations to broaden the EV charging network and identify potential equity issues surrounding charging station placements.},
booktitle = {Proceedings of the 4th ACM SIGSPATIAL International Workshop on Advances in Resilient and Intelligent Cities},
pages = {23–26},
numpages = {4},
keywords = {KDE, charging demand, data fusion, electric vehicle, least cost path},
location = {Beijing, China},
series = {ARIC '21}
}


@article{heo_optimal_2024,
	title = {Optimal planning for electric vehicle fast charging stations placements in a city scale using an advantage actor-critic deep reinforcement learning and geospatial analysis},
	volume = {113},
	issn = {2210-6707},
	doi = {10.1016/j.scs.2024.105567},
	abstract = {The transition to Electric Vehicles (EVs) for reducing urban greenhouse gas emissions is hindered by the lack of public charging infrastructure, particularly fast-charging stations. Given that electric vehicle fast charging stations (EVFCS) can burden the electricity grid, it is crucial for EVFCS to adopt sustainable energy supply methods while accommodating the growing demands of EVs. Despite recent research efforts to optimize the placement of renewable-powered EV charging stations, current planning methods face challenges when applied to a complex city scale and integrating with renewable energy resources. This study thus introduces a robust decision-making model for optimal EVFCS placement planning integrated with solar power supply in a large and complex urban environment (e.g., Chicago), utilizing an advantage actor-critic (A2C) deep reinforcement learning (DRL) approach. The model balances traffic demand with energy supply, strategically placing charging stations in areas with high traffic density and solar potential. As a result, the model is used to optimally place 1,000 charging stations with a random starting search approach, achieving total reward values of 74.30 \%, and estimated the capacities of potential EVFCS. This study can inform the identification of suitable locations to advance the microgrid-based charging infrastructure systems in large urban environments. © 2024 Elsevier Ltd},
	language = {English},
	journal = {Sustainable Cities and Society},
	author = {Heo, Jae and Chang, Soowon},
	year = {2024},
	note = {Publisher: Elsevier Ltd},
	keywords = {Advantage actor-critic, Deep reinforcement learning, Electric vehicle fast charging station, Geospatial analysis, Infrastructure planning},
	
}

@article{bian_planning_2022,
	title = {Planning of electric vehicle fast-charging station based on {POI} interest point division, functional area, and multiple temporal and spatial characteristics},
	volume = {8},
	issn = {2352-4847},
	url = {https://www.sciencedirect.com/science/article/pii/S2352484722020960},
	doi = {https://doi.org/10.1016/j.egyr.2022.10.161},
	abstract = {There are some problems with the fast-charging station of urban electric vehicles (EV), including blind construction, unreasonable planning location, and neglect of user requirements. This paper presents a planning method considering functional zoning and traffic influencing factors. Firstly, the planning area’s POI points and road network information are processed based on the geographic information software ArcGIS, and the urban functional zoning is divided. Then, two factors that affect the user’s time-consuming cost are studied, such as regional traffic congestion and signal waiting time. Secondly, according to the initial location of the user, the road network adjacency matrix, and the probability function of the user selecting the fast-charging station, the Floyd algorithm is used to calculate the time-consuming cost of the user to the fast-charging station. In order to reflect the profitability of the fast-charging station, the payback period function is also introduced. Finally, the MOSAPSO algorithm is used to solve the multi-objective function composed of the investment cost, operation, and maintenance cost, payback period, and user time-consuming cost of the fast-charging station. The optimized site selection and management layout of fast charging stations provide a certain reference for urban EV fast charging stations.},
	journal = {Energy Reports},
	author = {Bian, Haihong and Zhou, Chengang and Guo, Zhengyang and Wang, Ximeng and He, Ying and Peng, Shan},
	year = {2022},
	keywords = {Charging station planning, Functional area, MOSAPSO algorithm, Pareto optimality, POI points of interest, Signal duration, Traffic flow},
	pages = {831--840},
	annote = {2022 The 5th International Conference on Renewable Energy and Environment Engineering},
	
}
